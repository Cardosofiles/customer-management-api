APP_NAME=customer-management-api
PORT=3333
NODE_ENV=development
API_URL=http://localhost:3333
# URL do app frontend (usada nos links de callback dos e-mails de auth)
APP_URL=http://localhost:3000

# PostgreSQL (usado pelo container `db` no docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=customer_management

# Connection strings usadas pela aplicação
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customer_management?schema=public
REDIS_URL=redis://localhost:6379

CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
# Fastify trustProxy (opcional): vazio = seguro (usa o IP do socket, não spoofável).
# Atrás de um LB/reverse proxy, use o nº de hops confiáveis (ex.: 1) ou o CIDR do proxy.
# TRUST_PROXY=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3333

RESEND_API_KEY=
EMAIL_FROM=
